generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique @db.VarChar(191)
  password      String?  @db.VarChar(255) // Cho phép null vì login Google không có pass
  name          String?  @db.VarChar(191) // Thêm tên người dùng từ Google
  image         String?  @db.Text         // Thêm ảnh đại diện từ Google
  provider      String   @default("credentials") // "google", "facebook", hoặc "credentials"
  providerId    String?  @unique // ID định danh của Google/Facebook cấp cho user
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  urls          Url[]

  @@map("users")
}

model Url {
  id            Int       @id @default(autoincrement())
  originalUrl   String    @db.Text
  shortCode     String?    @unique @db.VarChar(20)
  title         String?   @db.VarChar(191)
  clickCount    Int       @default(0)
  userId        Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  expiresAt     DateTime?
  lastClickedAt DateTime?

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  clicks Click[]
  qrCode QrCode?

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([clickCount])
  @@index([clickCount, createdAt])
  @@index([lastClickedAt])
  @@map("urls")
}

model QrCode {
  id          Int      @id @default(autoincrement())
  urlId       Int      @unique
  imageData   String   @db.MediumText
  contentType String   @default("image/png") @db.VarChar(50)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  url Url @relation(fields: [urlId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@map("qr_codes")
}

model Click {
  id          BigInt   @id @default(autoincrement())
  urlId       Int
  ipAddress   String?  @db.VarChar(64)
  userAgent   String?  @db.VarChar(512)
  referer     String?  @db.VarChar(512)
  countryCode String?  @db.Char(2)
  clickedAt   DateTime @default(now())

  url Url @relation(fields: [urlId], references: [id], onDelete: Cascade)

  @@index([urlId, clickedAt])
  @@index([clickedAt])
  @@map("clicks")
}

model QRCode {
  id        Int      @id @default(autoincrement())
  urlId     Int      @unique
  qrData    String   @db.LongText  // Base64 encoded image (PNG) or SVG string
  format    String   @default("png")  // "png" or "svg"
  size      Int      @default(300)  // QR code size (px)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  url       Url      @relation(fields: [urlId], references: [id], onDelete: Cascade)

  @@map("qr_codes")
}
